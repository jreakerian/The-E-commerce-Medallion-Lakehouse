# ============================================================
# AWS Configuration
# ============================================================
AIRFLOW__SECRETS__BACKEND=airflow.providers.amazon.aws.secrets.secrets_manager.SecretsManagerBackend
AIRFLOW__SECRETS__BACKEND_KWARGS={"connections_prefix": "airflow/connections", "variables_prefix": "airflow/variables"}
AWS_DEFAULT_REGION=us-east-2
AIRFLOW_CONN_AWS_DEFAULT=aws://
AWS_ACCESS_KEY_ID=<your-aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-aws-secret-access-key>

# ============================================================
# Snowflake Configuration
# ============================================================
SNOWFLAKE_ACCOUNT=<your-snowflake-account>
SNOWFLAKE_USER=<your-snowflake-user>
SNOWFLAKE_PASSWORD=<your-snowflake-password>
SNOWFLAKE_ROLE=OLIST_ROLE
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=OLIST_LAKEHOUSE

# Key-pair auth: path to your rsa_key.p8 file (store outside the repo)
PRIVATE_KEY_PATH=<absolute-path-to-rsa_key.p8>
# Passphrase for encrypted .p8 key; leave empty if key is not encrypted
PRIVATE_KEY_PASSPHRASE=<your-passphrase>

# ============================================================
# dbt Configuration
# ============================================================
DBT_PROFILES_DIR=.
DBT_PROJECT_DIR=.
DBT_PARTIAL_PARSE=False

# ============================================================
# API Keys (optional)
# ============================================================
SEC_API_KEY=
MASSIVE_API_KEY=
